{
  "name": "agent-harness-cli",
  "version": "1.0.0",
  "description": "Scalable AI Agent Harness Generator for Complex Multi-Language Codebases",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "harness-gen": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && node ./dist/index.js",
    "test": "npm run build && node --test dist/tests/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "glob": "^11.0.1",
    "graphlib": "^2.1.8",
    "tree-sitter": "^0.21.1",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/graphlib": "^2.1.12",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}